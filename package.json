{
  "name": "wuwacalculator",
  "private": true,
  "version": "0.0.0",
  "license": "ISC",
  "type": "module",
  "engines": {
    "node": "^25.8.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "ingest:resonators": "node scripts/ingest/fetchResonators.mjs",
    "ingest:resonators:index": "node scripts/ingest/buildResonatorIndex.mjs --source-data-dir ingest/resonators --output-dir ingest/resonators/runtime",
    "ingest:resonators:module": "node scripts/ingest/buildResonatorModule.mjs --input-file ingest/resonators/resonators.json",
    "ingest:echoes:module": "node scripts/ingest/buildEchoModule.mjs --input-file ../wuwacalculator/src/data/echoes.json",
    "ingest:weapons": "node scripts/ingest/fetchWeapons.mjs",
    "ingest:weapons:module": "node scripts/ingest/buildWeaponModule.mjs --input-file ingest/weapons/weapons.json",
    "sync:resonator-images": "node scripts/assets/syncResonatorImages.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-oauth/google": "^0.13.4",
    "lucide-react": "^0.544.0",
    "motion": "^12.38.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-icons": "^5.6.0",
    "react-resizable-panels": "^4.7.3",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.8.0",
    "tesseract.js": "^5.1.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@webgpu/types": "^0.1.69",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
