{
  "name": "wuwacalculator",
  "private": true,
  "version": "0.0.0",
  "license": "ISC",
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "postbuild": "node tools/seo/writeStaticRoutes.mjs",
    "seo:sync": "node tools/seo/writeStaticRoutes.mjs --sync-public",
    "lint": "eslint .",
    "preview": "vite preview",
    "dev:cloudflare": "wrangler dev",
    "deploy:cloudflare": "npm run build && wrangler deploy",
    "ingest:resonators": "node scripts/ingest/fetch/encore/resonators.mjs",
    "ingest:resonators:nanoka": "node scripts/ingest/fetch/nanoka/resonators.mjs",
    "ingest:resonators:index": "node scripts/ingest/build/resonators/index.mjs --source-data-dir ingest/resonators --output-dir ingest/resonators/runtime",
    "ingest:resonators:module": "node scripts/ingest/build/resonators/module.mjs --input-file ingest/resonators/resonators.json",
    "ingest:echoes": "node scripts/ingest/fetch/nanoka/echoes.mjs",
    "ingest:echoes:module": "node scripts/ingest/build/echoes/module.mjs",
    "ingest:enemies": "node scripts/ingest/fetch/encore/enemies.mjs",
    "ingest:enemies:module": "node scripts/ingest/build/enemies/module.mjs",
    "ingest:weapons": "node scripts/ingest/fetch/encore/weapons.mjs",
    "ingest:weapons:nanoka": "node scripts/ingest/fetch/nanoka/weapons.mjs",
    "ingest:weapons:module": "node scripts/ingest/build/weapons/module.mjs --input-file ingest/weapons/weapons.json",
    "ingest:spine": "node scripts/ingest/fetch/nanoka/spine.mjs",
    "ingest:sequence-icons": "node scripts/ingest/fetch/nanoka/sequenceIcons.mjs",
    "render:spine-setup": "node scripts/assets/renderSpineSetup.mjs",
    "sync:resonator-images": "node scripts/assets/syncResonatorImages.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@codemirror/lang-css": "^6.3.1",
    "@esotericsoftware/spine-core": "4.1.23",
    "@esotericsoftware/spine-webgl": "4.1.23",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-oauth/google": "^0.13.4",
    "@uiw/react-codemirror": "^4.25.10",
    "axios": "1.15.2",
    "html-to-image": "^1.11.13",
    "lucide-react": "^0.544.0",
    "motion": "^12.38.0",
    "react": "^19.2.0",
    "react-colorful": "^5.6.1",
    "react-dom": "^19.2.0",
    "react-icons": "^5.6.0",
    "react-resizable-panels": "^4.7.3",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.8.0",
    "tesseract.js": "^5.1.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@webgpu/types": "^0.1.69",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "sharp": "^0.34.5",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vite-plugin-svgr": "^5.2.0",
    "vitest": "^4.0.18",
    "wrangler": "^4.81.1"
  }
}
